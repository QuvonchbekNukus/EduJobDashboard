APP_NAME="EduJobDashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://edujobdashboard.uz

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edujobdashboard
DB_USERNAME=root
DB_PASSWORD=

# Cache Configuration
CACHE_DRIVER=redis
CACHE_STORE=redis

# Queue Configuration
QUEUE_CONNECTION=redis
QUEUE_DRIVER=redis

# Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@edujobdashboard.uz"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_URLS=false

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=edujobdashboard.uz,www.edujobdashboard.uz

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_DISABLE_SSL_VERIFY=false

# Bot API Configuration
BOT_API_BASE_URL=https://edujobdashboard.uz/api
BOT_API_TOKEN=your_unique_bot_api_token_here
BOT_TIMEOUT=30
BOT_LOG_LEVEL=warning
BOT_DOWNLOAD_DIR=/var/www/bot/downloads

# Payment Provider Configuration
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_MERCHANT_KEY=
CLICK_TEST_MODE=false

PAYME_MERCHANT_ID=
PAYME_API_URL=https://checkout.paycom.uz/api
PAYME_TEST_MODE=false

# Application Settings
APP_TIMEZONE=Asia/Tashkent
APP_LOCALE=en
APP_FALLBACK_LOCALE=uz

# Vendor Encryption
VITE_API_BASE_URL=https://edujobdashboard.uz

# Redis Configuration (Optional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Broadcast Configuration (Optional)
BROADCAST_DRIVER=redis
BROADCAST_CONNECTION=redis
